// Companion Scheduling — MVP schema (SQLite locally; swap to Postgres in production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PARTNER
  CLIENT
  /// クライアント企業のスポンサー。通常クライアント機能 + 自社メンバーの予定一覧（読み取り専用）。
  CLIENT_ADMIN
}

enum MessageKind {
  STANDARD
  SLOT_PROPOSAL
  SCHEDULE_CONFIRMED
  VOTE_SUMMARY
}

enum NegotiationStatus {
  AWAITING_CLIENT_RESPONSE
  NEEDS_NEW_PROPOSAL
  AWAITING_PARTNER_CONFIRM
  CONFIRMED
  SUPERSEDED
}

enum SlotVote {
  YES
  NO
}

/// グローバル（テナント単位）の既定。管理者が編集。
model AppSettings {
  id                          String   @id @default("app")
  slotDurationMinutes         Int      @default(30)
  totalSessions               Int      @default(6)
  timezone                    String   @default("Asia/Tokyo")
  /// 候補日時の選択可能時間帯（時）
  slotEarliestHour            Int      @default(8)
  slotLatestHour              Int      @default(20)
  /// 土日も候補日として選択可能か
  allowWeekends               Boolean  @default(false)
  /// JSON: { [sessionNumber: number]: string[] } 各回のレポートに追加するパートナー設問
  partnerExtraQuestionsByRound Json?
  updatedAt                   DateTime @updatedAt
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  displayName  String
  role         Role
  googleSub    String?   @unique
  firebaseUid  String?   @unique
  /// Soft delete: ログインを完全に拒否しつつ過去のログを保持。
  deletedAt    DateTime?
  /// 所属クライアント企業 ID（クライアント / クライアント管理者の集計単位）
  companyId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partnerMatches Match[] @relation("PartnerUser")
  clientMatches  Match[] @relation("ClientUser")

  messages              Message[]
  passwordResetTokens   PasswordResetToken[]
  partnerZoom           PartnerZoomProfile?
  availabilityTemplates AvailabilityTemplate[]
  fta                   UserFta?
}

model UserFta {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

/// Fixed Zoom room per partner (URL + optional pass); injected into confirmations.
model PartnerZoomProfile {
  id        String @id @default(cuid())
  partnerId String @unique
  partner   User   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  zoomUrl   String
  zoomPass  String?
  updatedAt DateTime @updatedAt
}

/// Optional weekly template (minutes from midnight, weekday 0=Sun .. 6=Sat).
model AvailabilityTemplate {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekday      Int
  startMinutes Int
  endMinutes   Int
}

/// Pre-approved 1:1 relationship between partner and client.
model Match {
  id        String @id @default(cuid())
  partnerId String
  clientId  String
  partner   User @relation("PartnerUser", fields: [partnerId], references: [id], onDelete: Cascade)
  client    User @relation("ClientUser", fields: [clientId], references: [id], onDelete: Cascade)

  messages     Message[]
  negotiations Negotiation[]

  createdAt DateTime @default(now())

  @@unique([partnerId, clientId])
}

model Message {
  id        String      @id @default(cuid())
  matchId   String
  match     Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  kind      MessageKind @default(STANDARD)
  payload   Json?
  /// "ALL" | "CLIENT" | "PARTNER" 表示対象（管理者は常に閲覧可）
  audience  String      @default("ALL")
  createdAt DateTime    @default(now())
}

model Negotiation {
  id      String            @id @default(cuid())
  matchId String
  match   Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sessionNumber Int         @default(1)
  round   Int               @default(1)
  status  NegotiationStatus @default(AWAITING_CLIENT_RESPONSE)

  /// 確定時にスナップショットされる Zoom 情報（後でパートナーが URL を変えても、確定済みは固定）
  confirmedZoomUrl  String?
  confirmedZoomPass String?
  /// 確定後に変更希望が出された時刻。新しい round が CONFIRMED されたらクリア。
  rescheduleRequestedAt DateTime?

  slots Slot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Slot {
  id            String      @id @default(cuid())
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  startAt       DateTime
  endAt         DateTime
  clientVote    SlotVote?
  isConfirmed   Boolean     @default(false)
}

/// 1on1終了後にクライアント＆パートナー宛て案内（チャット投稿＋通知メール）を送るジョブ
model SessionFeedbackEmailJob {
  id             String    @id
  negotiationId String
  matchId        String
  clientId       String
  slotEndAt      DateTime
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
}

/// クライアントが各セッションごとに送るフィードバック（1マッチ×回数で1件）
model SessionFeedback {
  id                     String   @id @default(cuid())
  matchId                String
  sessionNumber          Int
  clientId               String
  /// q1〜q3, q5(自由), q7(自由) を JSON で保存（質問 ID → 回答テキスト）
  answers                Json
  satisfactionScore      Int?
  partnerChange          String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([matchId, sessionNumber])
}

/// パートナーが各セッションごとに書くレポート（1マッチ×回数で1件）
model SessionReport {
  id            String   @id @default(cuid())
  matchId       String
  sessionNumber Int
  partnerId     String
  reflection    String   @default("")
  /// 追加質問の回答 JSON: { [questionIndex]: string }
  extraAnswers  Json?
  createdAt     DateTime @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([matchId, sessionNumber])
}

/// 管理者通知フィード
model AdminNotification {
  id            String   @id @default(cuid())
  type          String
  matchId       String?
  sessionNumber Int?
  actorUserId   String?
  actorRole     String?
  summary       String
  link          String?
  readAt        DateTime?
  createdAt     DateTime @default(now())
}

/// パートナー / クライアント向け通知フィード
model MemberNotification {
  id              String   @id @default(cuid())
  recipientUserId String
  type            String
  matchId         String?
  sessionNumber   Int?
  actorUserId     String?
  actorRole       String?
  summary         String
  link            String?
  readAt          DateTime?
  createdAt       DateTime @default(now())

  @@index([recipientUserId, readAt])
  @@index([recipientUserId, createdAt])
}
